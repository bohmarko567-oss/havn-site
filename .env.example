# ── HAVN checkout backend ─────────────────────────────────────────────
# Copy to .env for local dev (server.local.js loads it), and add each var
# in Vercel → Project → Settings → Environment Variables for production.
# With NO variables set, /api/checkout runs in DEMO mode (fake success page).

# 1) Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# Developers → Webhooks → add endpoint https://YOUR-DOMAIN/api/stripe-webhook
# events: checkout.session.completed, invoice.paid  → copy the signing secret
STRIPE_WEBHOOK_SECRET=
# set to 1 only after configuring Stripe Tax (origin address + registrations)
STRIPE_TAX=

# 2) Order alerts + email capture — resend.com (free: 100 emails/day)
OWNER_EMAIL=bohmarko567@gmail.com
RESEND_API_KEY=
# optional: verified-domain sender, e.g. "HAVN <orders@yourdomain.com>"
EMAIL_FROM=
# optional: Resend Audience for the newsletter/waitlist
RESEND_AUDIENCE_ID=

# 2b) Analytics — server-side purchase events into Plausible (optional).
# Set to your Plausible site domain (e.g. havn.co) after creating the site there;
# also uncomment the <script> tag in index.html + success.html <head>.
PLAUSIBLE_DOMAIN=

# 3) Site
# canonical https origin used in Stripe redirects/product images when the
# request origin is unusable (optional — request origin is preferred)
SITE_URL=
# shipping economics (cents) — defaults: one-time free over $79, subscriptions
# free from $30/mo, else $6.95
FREE_SHIP_CENTS=7900
FREE_SUB_SHIP_CENTS=3000
SHIP_CENTS=695

# 4) OPTIONAL phase-2: hands-free fulfillment via headless Shopify + partner app
# (see GO_LIVE.md → "Full automation" — leave empty at launch)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_VARIANT_MAP=
SHOPIFY_API_VERSION=

# owner-email deep link to the fulfillment dashboard (kept out of source)
FULFILL_DASH_URL=
